# App
APP_NAME=AI Presentation Builder
DEBUG=true
SECRET_KEY=change-me-to-a-random-secret

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ai_presentation_builder
DATABASE_URL_SYNC=postgresql+psycopg2://user:password@localhost:5432/ai_presentation_builder

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# LLM Provider (OpenAI-compatible)
LLM_PROVIDER=openai
LLM_API_KEY=sk-your-api-key
LLM_MODEL=gpt-4o-mini
LLM_MODEL_STRONG=gpt-4o
LLM_BASE_URL=https://api.openai.com/v1

# Storage
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./uploads
# S3-compatible:
# STORAGE_BACKEND=s3
# S3_ENDPOINT=https://s3.amazonaws.com
# S3_ACCESS_KEY=...
# S3_SECRET_KEY=...
# S3_BUCKET=ai-presentations

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Email (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Payment (optional)
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
